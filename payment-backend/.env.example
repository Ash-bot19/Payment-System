# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_test_...
STRIPE_API_KEY=sk_test_...

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_DB=payment_db
DATABASE_URL=postgresql+asyncpg://payment:payment@localhost:5432/payment_db
DATABASE_URL_SYNC=postgresql://payment:payment@localhost:5432/payment_db

# ── GCP / BigQuery — Phase 11 setup ──────────────────────────────────────────
GCP_PROJECT_ID=project-2f9d2775-493e-4e59-9b8
GCS_CHECKPOINT_BUCKET=gs://<GCS_BUCKET_NAME>/checkpoints
BIGQUERY_DATASET=payment_analytics
CLOUD_SQL_HOST=<private-ip-from-cloud-sql>
CLOUD_SQL_PORT=5432
DATABASE_URL=postgresql+asyncpg://payment:payment@<CLOUD_SQL_HOST>:5432/payment_db
DATABASE_URL_SYNC=postgresql://payment:payment@<CLOUD_SQL_HOST>:5432/payment_db
REDIS_HOST=<memorystore-host>
REDIS_PORT=6379
REDIS_URL=redis://<REDIS_HOST>:6379/0
GCS_BUCKET_NAME=<bucket-name>
# TODO: Phase 11 — service account key path for production
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── GCP Infra (Phase 11) — ephemeral resources ──────────────────────────────
# CLOUD_SQL_HOST=172.31.0.3       (gcloud sql instances describe payment-db --format="value(ipAddresses[0].ipAddress)")
# REDIS_HOST=10.101.168.91        (gcloud redis instances describe payment-redis --format="value(host)")
# GCS_BUCKET_NAME=payment-spark-checkpoints-1775139408  (created in infra plan 11-01)

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=INFO
DEFAULT_MERCHANT_ID=test_merchant

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
