# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_test_...
STRIPE_API_KEY=sk_test_...

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_DB=payment_db
DATABASE_URL=postgresql+asyncpg://payment:payment@localhost:5432/payment_db
DATABASE_URL_SYNC=postgresql://payment:payment@localhost:5432/payment_db

# ── GCP / BigQuery — Phase 11 setup ──────────────────────────────────────────
# TODO: Phase 11 — create GCP project, enable BigQuery API, set these values
GCP_PROJECT_ID=your-gcp-project-id
GCS_CHECKPOINT_BUCKET=gs://your-bucket/checkpoints
BIGQUERY_DATASET=payment_analytics
# TODO: Phase 11 — service account key path for production
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=INFO
DEFAULT_MERCHANT_ID=test_merchant

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
